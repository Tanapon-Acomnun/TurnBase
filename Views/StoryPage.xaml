<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TurnBase.Views.StoryPage"
             BackgroundColor="#040210"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*, Auto">

        <Image x:Name="ImgScene" 
               Grid.Row="0"
               Grid.RowSpan="2"
               Aspect="AspectFill" 
               Opacity="1" />

        <BoxView Grid.Row="0" 
                 Grid.RowSpan="2" 
                 Color="Black"
                 Opacity="0.3" />

        <ScrollView x:Name="StoryScrollView" 
                    Grid.Row="0" 
                    Margin="20"
                    VerticalOptions="End">
            <Label x:Name="LblStory" 
                   TextColor="White" 
                   FontSize="16" 
                   LineHeight="1.5"
                   FontFamily="Georgia" 
                   Margin="10, 20">
                <Label.Shadow>
                    <Shadow Brush="Black" Offset="2,2" Radius="3" Opacity="1" />
                </Label.Shadow>
            </Label>
        </ScrollView>

        <Grid Grid.Row="1" 
              ColumnDefinitions="Auto, *, Auto" 
              Padding="20,10,20,40"
              BackgroundColor="Transparent">

            <Button x:Name="BtnBack" 
                    Grid.Column="0" 
                    Text="◄ ย้อนกลับ" 
                    BackgroundColor="Transparent"
                    TextColor="#D8B4FE"
                    FontAttributes="Bold"
                    FontSize="16"
                    Clicked="OnBackClicked" 
                    IsVisible="False" />

            <Button x:Name="BtnNext" 
                    Grid.Column="2" 
                    Text="ถัดไป ►" 
                    BackgroundColor="Transparent"
                    TextColor="#D8B4FE"
                    FontAttributes="Bold"
                    FontSize="16"
                    Clicked="OnNextClicked" />

            <Button x:Name="BtnStartGame" 
                    Grid.Column="2" 
                    Text="เริ่มเกม" 
                    BackgroundColor="Transparent"
                    TextColor="#D8B4FE"
                    FontAttributes="Bold"
                    FontSize="16"
                    Clicked="OnStartGameClicked" 
                    IsVisible="False" />
        </Grid>
    </Grid>
</ContentPage>