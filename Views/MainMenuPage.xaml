<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TurnBase.Views.MainMenuPage"
             Title="MainMenuPage"
             BackgroundColor="#040210">

    <Grid>
        <Image Source="start.png" Aspect="AspectFill" Opacity="0.4"/>
        <BoxView Color="#040210" Opacity="0.55"/>

        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16">

            <Label Text="The Demon's Grail" FontSize="32"
                   TextColor="#c4a6ef" FontFamily="Georgia"
                   HorizontalOptions="Center"/>

            <Border Stroke="#6d28d9" StrokeThickness="1"
                    BackgroundColor="#1e0a38"
                    Padding="40,12" HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="4"/>
                </Border.StrokeShape>
                <Label Text="เริ่มเกม" FontSize="13"
                       TextColor="#c4b5fd" CharacterSpacing="3"
                       FontFamily="Georgia"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnStartClicked"/>
                </Border.GestureRecognizers>
            </Border>
            <StackLayout Spacing="20" HorizontalOptions="Center" VerticalOptions="Center">
                <Button Text="เล่นต่อ" Clicked="OnContinueClicked" BackgroundColor="Green" />
            </StackLayout>

        </VerticalStackLayout>
    </Grid>
</ContentPage>