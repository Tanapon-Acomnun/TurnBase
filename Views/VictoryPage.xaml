<?xml version="1.0" encoding="utf-8" ?>
<views:BaseGamePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:views="clr-namespace:TurnBase.Views"
                    x:Class="TurnBase.Views.VictoryPage"
                    Title="Victory"
                    BackgroundColor="#040210">

    <Grid>
        <Image Source="vitory.png" Aspect="AspectFill" Opacity="0.3"/>
        <BoxView Color="#040210" Opacity="0.6"/>

        <VerticalStackLayout Padding="30" Spacing="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Center">

            <!-- Trophy icon -->
            <Label Text="🏆" FontSize="52"
                   HorizontalOptions="Center"
                   Margin="0,0,0,12"/>

            <!-- Victory title -->
            <Label Text="VICTORY!"
                   FontSize="34" FontAttributes="Bold"
                   TextColor="#fbbf24" CharacterSpacing="6"
                   HorizontalOptions="Center"
                   FontFamily="Georgia"/>

            <!-- Divider -->
            <BoxView Color="#d97706" HeightRequest="1" WidthRequest="240"
                     HorizontalOptions="Center" Margin="0,16,0,16" Opacity="0.7"/>

            <!-- Victory message -->
            <Label Text="{Binding RewardText}"
                   FontSize="20"
                   TextColor="Gold"
                   HorizontalOptions="Center"/>
            <Label Text="{Binding CurrencyText}"
                   FontSize="18"
                   TextColor="White"
                   HorizontalOptions="Center"/> 

            <!-- Next Battle Button -->
            <Border Stroke="#7c3aed" StrokeThickness="1"
                    BackgroundColor="#1e0a38"
                    Padding="0,14" WidthRequest="220"
                    HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="4"/>
                </Border.StrokeShape>
                <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                    <Label Text="⚔️" FontSize="18" HorizontalOptions="Center"/>
                    <Label Text="PROCEED" FontSize="16"
                           TextColor="#c4b5fd" CharacterSpacing="1"
                           FontFamily="Georgia" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNextBattleClicked"/>
                </Border.GestureRecognizers>
            </Border>

        </VerticalStackLayout>
    </Grid>

</views:BaseGamePage>