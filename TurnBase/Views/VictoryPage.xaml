<?xml version="1.0" encoding="utf-8" ?>
<views:BaseGamePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:views="clr-namespace:TurnBase.Views"
                    x:Class="TurnBase.Views.VictoryPage"
                    Title="Victory">

    <VerticalStackLayout Padding="30"
                         Spacing="25"
                         VerticalOptions="Center"
                         HorizontalOptions="Center">

        <Label Text="Victory!"
               FontSize="36"
               HorizontalOptions="Center"/>

        <Label x:Name="VictoryMessageLabel"
               FontSize="20"
               HorizontalOptions="Center"/>

        <Button Text="Upgrade Character"
                Clicked="OnUpgradeClicked"
                WidthRequest="220"/>

        <Button Text="Next Battle"
                Clicked="OnNextBattleClicked"
                WidthRequest="220"/>

    </VerticalStackLayout>
</views:BaseGamePage>