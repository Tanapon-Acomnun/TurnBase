<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TurnBase.Views.CharacterSelectPage"
             Title="CharacterSelectPage"
             BackgroundColor="#040210">

    <Grid>
        <Image Source="start.png" Aspect="AspectFill" Opacity="0.4"/>
        <BoxView Color="#040210" Opacity="0.55"/>

        <ScrollView>
            <VerticalStackLayout Padding="24,48,24,32" Spacing="0">

                <Label Text="CHOOSE YOUR CLASS"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="#c4a6ef" CharacterSpacing="4"
                       HorizontalOptions="Center" FontFamily="Georgia"/>

                <BoxView Color="#4c1d95" HeightRequest="1" WidthRequest="300"
                         HorizontalOptions="Center" Margin="0,12,0,32" Opacity="0.7"/>

                <!-- Berserker Card -->
                <Border Stroke="#6d28d9" StrokeThickness="1"
                        BackgroundColor="#0f0920"
                        Margin="0,0,0,16" Padding="20,18">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="72,*,Auto" ColumnSpacing="16">
                        <Border Grid.Column="0" BackgroundColor="#0a0518"
                                Stroke="#7c3aed" StrokeThickness="1"
                                WidthRequest="64" HeightRequest="64"
                                HorizontalOptions="Center" VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4"/>
                            </Border.StrokeShape>
                            <Image Source="berserker.png" Aspect="AspectFit" Margin="2"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                            <Label Text="BERSERKER" FontSize="16" FontAttributes="Bold"
                                   TextColor="#c4a6ef" CharacterSpacing="2" FontFamily="Georgia"/>
                            <Label Text="High damage · Double Axe"
                                   FontSize="13" TextColor="#7c3aed" Opacity="0.9"/>
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="40,*"
                                  RowSpacing="3" ColumnSpacing="6" Margin="0,4,0,0">
                                <Label Grid.Row="0" Grid.Column="0" Text="STR" FontSize="10" TextColor="#8b5cf6"/>
                                <ProgressBar Grid.Row="0" Grid.Column="1" Progress="0.95" ProgressColor="#8b5cf6" VerticalOptions="Center"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="DEF" FontSize="10" TextColor="#8b5cf6"/>
                                <ProgressBar Grid.Row="1" Grid.Column="1" Progress="0.40" ProgressColor="#6d28d9" VerticalOptions="Center"/>
                                <Label Grid.Row="2" Grid.Column="0" Text="MGC" FontSize="10" TextColor="#8b5cf6"/>
                                <ProgressBar Grid.Row="2" Grid.Column="1" Progress="0.10" ProgressColor="#4c1d95" VerticalOptions="Center"/>
                            </Grid>
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#1e0a38"
                                Stroke="#6d28d9" StrokeThickness="1"
                                Padding="12,8" VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4"/>
                            </Border.StrokeShape>
                            <Label Text="SELECT" FontSize="11" TextColor="#c4b5fd"
                                   CharacterSpacing="1" FontFamily="Georgia"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnWarriorClicked"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </Border>

                <!-- Knight Card -->
                <Border Stroke="#6d28d9" StrokeThickness="1"
                        BackgroundColor="#0f0920"
                        Margin="0,0,0,16" Padding="20,18">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="72,*,Auto" ColumnSpacing="16">
                        <Border Grid.Column="0" BackgroundColor="#0a0518"
                                Stroke="#7c3aed" StrokeThickness="1"
                                WidthRequest="64" HeightRequest="64"
                                HorizontalOptions="Center" VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4"/>
                            </Border.StrokeShape>
                            <Image Source="knight.png" Aspect="AspectFit" Margin="2"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                            <Label Text="KNIGHT" FontSize="16" FontAttributes="Bold"
                                   TextColor="#c4a6ef" CharacterSpacing="2" FontFamily="Georgia"/>
                            <Label Text="Balanced · Sword &amp; Shield"
                                   FontSize="13" TextColor="#7c3aed" Opacity="0.9"/>
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="40,*"
                                  RowSpacing="3" ColumnSpacing="6" Margin="0,4,0,0">
                                <Label Grid.Row="0" Grid.Column="0" Text="STR" FontSize="10" TextColor="#8b5cf6"/>
                                <ProgressBar Grid.Row="0" Grid.Column="1" Progress="0.70" ProgressColor="#8b5cf6" VerticalOptions="Center"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="DEF" FontSize="10" TextColor="#8b5cf6"/>
                                <ProgressBar Grid.Row="1" Grid.Column="1" Progress="0.85" ProgressColor="#6d28d9" VerticalOptions="Center"/>
                                <Label Grid.Row="2" Grid.Column="0" Text="MGC" FontSize="10" TextColor="#8b5cf6"/>
                                <ProgressBar Grid.Row="2" Grid.Column="1" Progress="0.30" ProgressColor="#4c1d95" VerticalOptions="Center"/>
                            </Grid>
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#1e0a38"
                                Stroke="#6d28d9" StrokeThickness="1"
                                Padding="12,8" VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4"/>
                            </Border.StrokeShape>
                            <Label Text="SELECT" FontSize="11" TextColor="#c4b5fd"
                                   CharacterSpacing="1" FontFamily="Georgia"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnKnightClicked"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </Border>

                <!-- Wizard Card -->
                <Border Stroke="#6d28d9" StrokeThickness="1"
                        BackgroundColor="#0f0920"
                        Margin="0,0,0,16" Padding="20,18">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="72,*,Auto" ColumnSpacing="16">
                        <Border Grid.Column="0" BackgroundColor="#0a0518"
                                Stroke="#7c3aed" StrokeThickness="1"
                                WidthRequest="64" HeightRequest="64"
                                HorizontalOptions="Center" VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4"/>
                            </Border.StrokeShape>
                            <Image Source="wizard.png" Aspect="AspectFit" Margin="2"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                            <Label Text="WIZARD" FontSize="16" FontAttributes="Bold"
                                   TextColor="#c4a6ef" CharacterSpacing="2" FontFamily="Georgia"/>
                            <Label Text="High magic · Staff &amp; Tome"
                                   FontSize="13" TextColor="#7c3aed" Opacity="0.9"/>
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="40,*"
                                  RowSpacing="3" ColumnSpacing="6" Margin="0,4,0,0">
                                <Label Grid.Row="0" Grid.Column="0" Text="STR" FontSize="10" TextColor="#8b5cf6"/>
                                <ProgressBar Grid.Row="0" Grid.Column="1" Progress="0.20" ProgressColor="#8b5cf6" VerticalOptions="Center"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="DEF" FontSize="10" TextColor="#8b5cf6"/>
                                <ProgressBar Grid.Row="1" Grid.Column="1" Progress="0.25" ProgressColor="#6d28d9" VerticalOptions="Center"/>
                                <Label Grid.Row="2" Grid.Column="0" Text="MGC" FontSize="10" TextColor="#8b5cf6"/>
                                <ProgressBar Grid.Row="2" Grid.Column="1" Progress="0.98" ProgressColor="#4c1d95" VerticalOptions="Center"/>
                            </Grid>
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#1e0a38"
                                Stroke="#6d28d9" StrokeThickness="1"
                                Padding="12,8" VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4"/>
                            </Border.StrokeShape>
                            <Label Text="SELECT" FontSize="11" TextColor="#c4b5fd"
                                   CharacterSpacing="1" FontFamily="Georgia"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnWizardClicked"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </Border>

                <BoxView Color="#4c1d95" HeightRequest="1" WidthRequest="300"
                         HorizontalOptions="Center" Margin="0,8,0,0" Opacity="0.5"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>