<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TurnBase.Views.CharacterSelectPage"
             Title="CharacterSelectPage">
    
    <VerticalStackLayout Padding="20">
        <Label Text="Choose Your Class" FontSize="28"/>

        <Button Text="Wizard" Clicked="OnWizardClicked"/>
        <Button Text="Warrior" Clicked="OnWarriorClicked"/>
        <Button Text="Knight" Clicked="OnKnightClicked"/>
    </VerticalStackLayout>
</ContentPage>