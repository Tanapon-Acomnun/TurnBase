<?xml version="1.0" encoding="utf-8" ?>
<views:BaseGamePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:views="clr-namespace:TurnBase.Views"
                    x:Class="TurnBase.Views.UpgradePage"
                    Title="Upgrade">   
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Level Up!"
                   FontSize="32"
                   HorizontalOptions="Center" />

            <Label x:Name="PointsLabel"
                   FontSize="20"
                   HorizontalOptions="Center" />

            <!-- ATK -->
            <HorizontalStackLayout Spacing="10">
                <Label x:Name="AttackLabel"
                       Text="ATK: 0"
                       WidthRequest="150"/>

                <Button Text="+1"
                        Clicked="OnAttackUpgradeClicked"/>
            </HorizontalStackLayout>

            <!-- HP -->
            <HorizontalStackLayout Spacing="10">
                <Label x:Name="HPLabel"
                       Text="HP: 0"
                       WidthRequest="150"/>

                <Button Text="+5"
                        Clicked="OnHPUpgradeClicked"/>
            </HorizontalStackLayout>

            <!-- MP -->
            <HorizontalStackLayout Spacing="10">
                <Label x:Name="MPLabel"
                       Text="MP: 0"
                       WidthRequest="150"/>

                <Button Text="+5"
                        Clicked="OnMPUpgradeClicked"/>
            </HorizontalStackLayout>

            <Button Text="Confirm"
                    Clicked="OnConfirmClicked"
                    Margin="0,30,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</views:BaseGamePage>