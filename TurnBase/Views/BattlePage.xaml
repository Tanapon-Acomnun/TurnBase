<?xml version="1.0" encoding="utf-8" ?>
<views:BaseGamePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:views="clr-namespace:TurnBase.Views"
                    x:Class="TurnBase.Views.BattlePage"
                    Title="BattlePage">
    <VerticalStackLayout Padding="20" Spacing="15">

        <!-- Enemy -->
        <Label Text="{Binding Enemy.Name}" FontSize="24" />
        <Label Text="HP:" />
        <Label Text="{Binding Enemy.CurrentHP}" />

        <!-- Player -->
        <Label Text="{Binding Player.Name}" FontSize="24" />
        <Label Text="HP:" />
        <Label Text="{Binding Player.CurrentHP}" />
        <Label Text="MP:" />
        <Label Text="{Binding Player.MP}" />

        <!-- Battle Log -->
        <Label Text="{Binding BattleLog}" LineBreakMode="WordWrap" />

        <!-- Actions -->
        <Button Text="Attack" Clicked="OnAttackClicked"/>
        <Button Text="Skill" Clicked="OnSkillClicked" />
        <Button Text="Guard" Clicked="OnGuardClicked" />
        <Button Text="Item" Clicked="OnItemClicked" />

    </VerticalStackLayout>
</views:BaseGamePage>