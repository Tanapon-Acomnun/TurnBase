<views:BaseGamePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:views="clr-namespace:TurnBase.Views"
                    x:Class="TurnBase.Views.SkillPage"
                    Title="Skills">

    <VerticalStackLayout Padding="30"
                         Spacing="20"
                         VerticalOptions="Center">

        <Label Text="Skills"
               FontSize="32"
               HorizontalOptions="Center"/>

        <!-- Dynamic skill buttons will go here -->

        <VerticalStackLayout x:Name="SkillContainer"
                     Spacing="12"/>

        <Button Text="Back"
                Clicked="OnBackClicked"/>

    </VerticalStackLayout>

</views:BaseGamePage>